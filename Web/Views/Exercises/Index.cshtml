@model IEnumerable<Exercise>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4>Упражнения</h4>
    <a asp-action="Create" class="btn btn-primary">Добави</a>
</div>

<table class="table table-hover shadow-sm">
    <thead>
        <tr>
            <th>Име на упражнение</th>
            <th>Категория</th>
            <th class="text-end">Действия</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Name</td>
                <td><span class="badge bg-secondary">@item.Category.Name</span></td>
                <td class="text-end">
                    <a asp-action="Edit" asp-route-id="@item.Id" class="text-decoration-none">Редактирай</a>
                    |
                    <a asp-action="Delete" asp-route-id="@item.Id" class="text-decoration-none">Изтрий</a>
                </td>
            </tr>
        }
    </tbody>
</table>