@model Exercise

<h2>Редактиране на упражнение</h2>

<form asp-action="Edit">
    <input type="hidden" asp-for="Id" />
    <div class="form-group mb-3">
        <label class="form-label">Име</label>
        <input asp-for="Name" class="form-control" />
    </div>
    <div class="form-group mb-3">
        <label class="form-label">Категория</label>
        <select asp-for="CategoryId" class="form-select" asp-items="ViewBag.CategoryId"></select>
    </div>
    <button type="submit" class="btn btn-warning">Обнови</button>
    <a asp-action="Index" class="btn btn-secondary">Отказ</a>
</form>