@model Web.Models.Exercise

<h3>Добавяне на ново упражнение</h3>
<div asp-validation-summary="All" class="text-danger"></div>
<div class="row">
    <div class="col-md-4">
        <form asp-action="Create">
            <div class="form-group mb-3">
                <label class="form-label">Име на български</label>
                <input asp-for="Name" class="form-control" placeholder="напр. Набирания" />
            </div>
            <div class="form-group mb-3">
                <label class="form-label">Категория</label>
                <select asp-for="CategoryId" class="form-select" asp-items="ViewBag.Categories"></select>
            </div>
            <button type="submit" class="btn btn-primary">Запази</button>
            <a asp-action="Index" class="btn btn-link">Отказ</a>
        </form>
    </div>
</div>