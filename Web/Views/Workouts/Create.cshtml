@model Workout

<h4>Нова тренировка</h4>
<div asp-validation-summary="All" class="text-danger"></div>

<form asp-action="Create">
    <div class="card mb-4">
        <div class="card-body">
            <div class="form-group mb-3">
                <label>Име на тренировката</label>
                <input asp-for="Name" class="form-control" placeholder="напр. Сутрешна сила" />
            </div>
            <div class="form-group">
                <label>Дата</label>
                <input asp-for="Date" type="date" class="form-control" value="@DateTime.Now.ToString("yyyy-MM-dd")" />
            </div>
        </div>
    </div>


    <button type="submit" class="btn btn-primary">Запази</button>
    <a asp-action="Index" class="btn btn-link">Отказ</a>
</form>