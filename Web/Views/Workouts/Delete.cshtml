@model Workout

<h3>Сигурни ли сте, че искате да изтриете тази тренировка?</h3>
<div>
    <h4>@Model.Name</h4>
    <p>Дата: @Model.Date.ToShortDateString()</p>
    
    <form asp-action="DeleteConfirmed">
        <input type="hidden" asp-for="Id" />
        <button type="submit" class="btn btn-danger">Да, Изтрий</button>
        <a asp-action="Index" class="btn btn-secondary">Отказ</a>
    </form>
</div>