@model IEnumerable<Web.Models.Workout>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4>Моите Тренировки</h4>
    <a asp-action="Create" class="btn btn-primary">Добави</a>
</div>

<table class="table table-hover">
    <thead>
        <tr>
            <th>Дата</th>
            <th>Име на тренировка</th>
            <th class="text-center">Брой упражнения</th>
            <th class="text-end">Действия</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Date.ToString("dd.MM.yyyy")</td>
                <td>@item.Name</td>
                <td class="text-center">@item.WorkoutLogs.Count</td>
                <td class="text-end">
                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-info">Детайли</a>
                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-success">Редактирай</a>
                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger">Изтрий</a>
                </td>
            </tr>
        }
    </tbody>
</table>